# Copy to .env and fill in. The script auto-loads .env (python-dotenv).
# Every value below has a sane default in the code except the provider
# credentials, which are required for live sending (not for --dry-run).

# --- NEWS SOURCE ------------------------------------------------------------
# Where headlines come from: "gdelt" (default, no key needed) or "rss".
SOURCE=gdelt

# --- GDELT (SOURCE=gdelt) ---------------------------------------------------
# Search query. Supports "phrases", OR inside (parentheses), and trailing
# operators like sourcelang:english, sourcecountry:IN, domain:thehindu.com.
# Keep at least one real keyword (operators-only queries are rejected).
GDELT_QUERY=("data privacy" OR "data protection" OR "DPDP Act" OR "AI governance" OR cybersecurity) sourcelang:english
GDELT_TIMESPAN=1h              # look-back per run, e.g. 15min, 1h, 24h, 7d
GDELT_MAX=75                   # max records to fetch (hard cap 250)
GDELT_RETRIES=4                # retries on GDELT 429/5xx
GDELT_BACKOFF=6                # backoff seconds, multiplied by attempt number

# --- RSS (SOURCE=rss) -------------------------------------------------------
# Only used when SOURCE=rss. Comma-separated Google Alert RSS feed URL(s).
# Optionally label one as "label|url". Needs feedparser installed.
ALERT_FEEDS=DPDP watch|https://www.google.com/alerts/feeds/XXXX/YYYY

# --- REQUIRED FOR LIVE SENDING (not needed for --dry-run) -------------------
PROVIDER=whapi                 # or: wassenger
PROVIDER_TOKEN=
GROUP_ID=                      # Whapi: full JID like 120363xxxx@g.us

# --- OPTIONAL: Groq relevance gate (leave GROQ_API_KEY blank to forward all) -
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
SCORE_THRESHOLD=60
# SCORE_TOPIC=AI governance, data privacy, and cybersecurity ...

# --- OPTIONAL: newsletter-fit pass (needs GROQ_API_KEY) ---------------------
# off | tag (prefix good picks) | filter (only post good picks)
NEWSLETTER_MODE=off
# NEWSLETTER_TAG=⭐ NEWSLETTER PICK
# NEWSLETTER_CRITERIA=substantive developments — new laws, major fines, ...

# --- OPTIONAL: tuning -------------------------------------------------------
SEEN_DB=seen.db                # de-dupe memory; point at a persistent path in prod
LOOP_INTERVAL=900              # seconds, for --loop mode
SEND_DELAY=4                   # seconds between sends
MAX_POSTS_PER_RUN=0            # cap items per run (0 = no limit); overflow posts next run
